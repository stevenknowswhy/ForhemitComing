# =====================================
# Forhemit Marketing Site Environment
# =====================================
# Copy this file to .env.local and fill in your actual values
#
# Skip Zod env validation (e.g. next lint, or partial local env):
# SKIP_ENV_VALIDATION=true

# UploadThing Configuration (for file uploads)
UPLOADTHING_TOKEN=your_uploadthing_token_here
UPLOADTHING_APP_ID=your_uploadthing_app_id_here

# Unsplash API Configuration (for images)
UNSPLASH_APPLICATION_ID=your_unsplash_app_id
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
UNSPLASH_SECRET_KEY=your_unsplash_secret_key

# Convex Configuration (shared backend)
NEXT_PUBLIC_CONVEX_URL=https://your-convex-deployment.convex.cloud
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-convex-deployment.convex.site

# Site URL
NEXT_PUBLIC_SITE_URL=https://forhemit.com

# Preview gate (pre-launch): visitors without cookie are sent to /coming-soon
# Override the default invitation code (default is Forhemit-access2026)
# PREVIEW_INVITATION_CODE=your-secret-code
# Disable the gate entirely (e.g. local dev or after public launch)
# PREVIEW_GATE_DISABLED=true

# Note: This marketing site does NOT use Clerk authentication
# Admin functionality has been moved to ForhemitAdminWebsite
