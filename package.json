{
  "name": "forhemit-monorepo",
  "version": "0.1.0",
  "private": true,
  "main": "packages/shared/src/index.ts",
  "module": "packages/shared/src/index.ts",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:eslint": "eslint .",
