    "convex:once": "pnpm --filter @forhemit/convex run convex:once"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.6",
    "eslint": "^10.4.0",
    "eslint-plugin-next": "^0.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "turbo": "^2.4.4",
    "typescript-eslint": "^8.60.0"
  },
  "pnpm": {
    "overrides": {
      "effect": "^3.20.1"
    }
  }
