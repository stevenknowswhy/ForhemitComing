UPLOADTHING_TOKEN=your_token_here

# External admin site (separate repo/app)
# Example: https://admin.forhemit.com
NEXT_PUBLIC_ADMIN_URL=

# =====================================
# Email Configuration (Resend)
# =====================================
# Get your API key from https://resend.com
RESEND_API_KEY=re_your_api_key_here

# The "from" email address (must be verified in Resend)
FROM_EMAIL=contact@forhemit.com

# The admin email that receives notifications
ADMIN_EMAIL=stefano.stokes@forhemit.com

# =====================================
# Telegram Notifications (optional but recommended)
# =====================================
# Create a bot with @BotFather and copy the API token
TELEGRAM_BOT_TOKEN=

# Chat/channel ID that receives notifications (numeric ID)
TELEGRAM_CHAT_ID=
