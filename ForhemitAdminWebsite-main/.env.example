# =====================================
# Forhemit Admin Site Environment
# =====================================
# Copy this file to .env.local and fill in your actual values
#
# Skip Zod env validation (e.g. next lint, or partial local env):
# SKIP_ENV_VALIDATION=true

# Clerk Authentication (Required)
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Clerk URLs Configuration
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/admin

# Clerk Webhook Secret (Required for user management)
# 1. Go to Clerk Dashboard → Webhooks → Add Endpoint
# 2. Set URL to: https://your-domain.com/api/webhooks/clerk
# 3. Select events: user.created, user.updated
# 4. Copy the signing secret here
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# UploadThing Configuration (for file uploads)
UPLOADTHING_TOKEN=your_uploadthing_token_here
UPLOADTHING_APP_ID=your_uploadthing_app_id_here

# Unsplash API Configuration (for document generation)
UNSPLASH_APPLICATION_ID=your_unsplash_app_id
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
UNSPLASH_SECRET_KEY=your_unsplash_secret_key

# Convex Configuration (shared backend - MUST match marketing site)
NEXT_PUBLIC_CONVEX_URL=https://your-convex-deployment.convex.cloud
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-convex-deployment.convex.site

# Convex deploy key (for `npx convex deploy` / GitHub Actions only — keep in .env.local or CI secrets)
# CONVEX_DEPLOY_KEY=dev:deployment-name|base64payload

# Convex + Clerk (REQUIRED on the Convex deployment, not just here)
# Same value as Clerk Dashboard → API Keys → "Frontend API URL"
# Set on Convex: Dashboard → Settings → Environment Variables, OR:
#   npx convex env set CLERK_JWT_ISSUER_DOMAIN "https://verb-noun-00.clerk.accounts.dev"
# Then run: npx convex dev  (or deploy) so auth.config.ts syncs.
CLERK_JWT_ISSUER_DOMAIN=https://your-app.clerk.accounts.dev

# Site URL
NEXT_PUBLIC_SITE_URL=https://forhemit.website

# =====================================
# EMAIL RESTRICTIONS CONFIGURED IN:
# Clerk Dashboard → User & Authentication → Restrictions
# Add email domain allowlist: forhemit.com
#
# SUPER ADMIN CONFIGURED IN:
# lib/clerk.ts → SUPER_ADMIN_EMAIL
# Default: stefano.stokes@forhemit.com
# =====================================

# =====================================
# Telegram (Convex deployment — not only Next.js)
# =====================================
# New contact form submissions schedule a Telegram alert from Convex.
# Set these in the Convex dashboard (same names) so scheduled actions can send:
#   TELEGRAM_BOT_TOKEN=
#   TELEGRAM_CHAT_ID=
# See EMAIL_TELEGRAM_SETUP.md and .env.local.example
# =====================================
