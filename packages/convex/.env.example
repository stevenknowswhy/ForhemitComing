# Convex CLI reads env from this folder when you run pnpm convex:* from the monorepo root.
#
# Option A — copy or symlink one app’s file (includes CONVEX_DEPLOYMENT + optional CONVEX_DEPLOY_KEY):
#   cp ../../apps/admin/.env.local .env.local
#   # or: ln -sf ../../apps/admin/.env.local .env.local
#
# Option B — minimal file (match the deployment used by NEXT_PUBLIC_CONVEX_URL in the apps):
#
CONVEX_DEPLOYMENT=dev:your-deployment-name
# CONVEX_DEPLOY_KEY=dev:deployment|...   # required for `pnpm convex:deploy` (never commit)
